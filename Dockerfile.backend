FROM node:18-alpine

WORKDIR /app

# Копируем package.json и package-lock.json
COPY package*.json ./

# Устанавливаем зависимости
RUN npm install

# Копируем исходный код (только нужные папки)
COPY server.js ./
COPY models ./models
COPY services ./services

# Создаем папку для uploads
RUN mkdir -p uploads

# Открываем порт
EXPOSE 3000

# Запускаем сервер
CMD ["node", "server.js"]